# ─────────────────────────────────────────────────────────────────────────────
# MyExpert — Web App Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: supabase.com → project → Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# ── OneSignal (web push) ──────────────────────────────────────────────────────
# Found at: app.onesignal.com → Settings → Keys & IDs
# Leave blank to disable push notifications (SMS will still work).
VITE_ONESIGNAL_APP_ID=<your-onesignal-app-id>

# ── Google Maps ───────────────────────────────────────────────────────────────
# Required for the worker map view and location picker.
# Found at: console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>
